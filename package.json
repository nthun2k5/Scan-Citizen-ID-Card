{
  "name": "cccd-scanner",
  "version": "1.0.0",
  "description": "Phần mềm quét Căn cước công dân qua cổng COM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.cccdscanner.app",
    "productName": "CCCD Scanner",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CCCD Scanner"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "robotjs": "^0.7.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "keywords": [
    "cccd",
    "scanner",
    "serial",
    "com",
    "vietnam"
  ],
  "author": "",
  "license": "MIT"
}
